# Telegram Bot Token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Allowed Telegram user IDs.
# Leave empty to skip ID filtering.
# Example: 123456789,987654321
ALLOWED_USER_IDS=

# Allowed Telegram usernames (without @), comma-separated.
# Leave empty to skip username filtering.
# Example: ilayarr,anastasiyaanastasia
ALLOWED_USERNAMES=

# Admin users allowed to run /reset_all.
# Recommended: set by username and/or user_id.
ADMIN_USER_IDS=
ADMIN_USERNAMES=

# Optional display names mapped by numeric user_id.
# Format: user_id:name,user_id:name
# Example: 123456789:Илья,987654321:Настя
USER_LABELS=

# Optional display names mapped by username.
# Format: username:name,username:name
# Example: ilayarr:Илья,anastasiyaanastasia:Настя
USER_LABELS_BY_USERNAME=

# Timezone for report calculations
TIMEZONE=Europe/Moscow

# SQLite database path
DB_PATH=./data/meditation.db

# Report scope:
# - global: aggregate all tracked users across all chats
# - chat: aggregate only inside current chat
REPORT_SCOPE=global

# Auto report schedule
# period: day | week | month
AUTO_REPORT_PERIOD=week
# For week period only: 0=Mon ... 6=Sun
AUTO_REPORT_WEEKDAY=0
# Local time in HH:MM
AUTO_REPORT_TIME=08:00

# Optional extra monthly report in addition to primary schedule.
# Sends monthly summary on the 1st day of month at specified time.
AUTO_REPORT_MONTHLY_ENABLED=true
AUTO_REPORT_MONTHLY_TIME=08:00

# Allow corrections as negative values (-5)
ALLOW_NEGATIVE_ENTRIES=false

# Protection from accidental huge values
MAX_ENTRY_MINUTES=180
